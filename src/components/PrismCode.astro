---
interface Props {
  code: string;
  label?: string;
}

const { code, label } = Astro.props;
---

<figure class="my-6">
  {
    label && (
      <figcaption
        class="mb-2 font-mono text-[10px] uppercase tracking-[0.14em] text-text-muted"
        style="font-family: var(--font-mono);"
      >
        {label}
      </figcaption>
    )
  }
  <pre
    class="overflow-x-auto rounded-lg border border-border bg-bg-elev-2 p-4 text-sm leading-relaxed text-text"
    style="font-family: var(--font-mono);"><code>{code}</code></pre>
</figure>
