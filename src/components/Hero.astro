---
import ArchitectureDiagram from "./ArchitectureDiagram.astro";
---

<section id="hero" class="relative overflow-hidden px-6 pt-12 pb-20 sm:px-10 sm:pt-16 sm:pb-28">
  <div id="hero-glow" class="hero-mouse-glow"></div>

  <div class="relative mx-auto max-w-[72rem]">
    <div class="grid items-center gap-12 lg:grid-cols-[1.05fr_1fr]">
      <div>
        <p
          class="font-mono text-xs uppercase tracking-[0.12em] text-accent"
          style="font-family: var(--font-mono);"
        >
          Data · AI · ML Engineering
        </p>

        <h1
          class="mt-5 font-light leading-[1.08] tracking-tight text-text"
          style="font-size: clamp(2.5rem, 6vw, 4.5rem);"
        >
          I build <span class="ink-underline">AI-powered systems</span> that turn manual
          workflows into automated infrastructure.
        </h1>

        <p class="mt-6 max-w-2xl text-base leading-relaxed text-text-dim sm:text-lg">
          Junior at the University of South Florida studying Artificial Intelligence, Analytics
          & Information Systems. Available <span class="text-text">Summer 2026</span> and
          <span class="text-text">Fall 2026</span> for Data, AI, and ML Engineering internships —
          also open to Data Science, Business Analytics, and Analyst roles.
        </p>

        <div class="mt-8 flex flex-wrap items-center gap-3">
          <a
            href="#flagship"
            class="inline-flex items-center gap-2 rounded-lg bg-accent px-4 py-2.5 text-sm font-medium text-white shadow-[0_1px_2px_rgba(194,90,42,0.25)] hover:bg-accent-hover transition-all duration-200 ease-out"
          >
            See the flagship project <span aria-hidden="true">→</span>
          </a>
          <a
            href="/resume.pdf"
            class="inline-flex items-center gap-2 rounded-lg border border-border-strong bg-bg-elev px-4 py-2.5 text-sm text-text hover:text-accent hover:border-accent transition-all duration-200 ease-out"
          >
            Résumé <span aria-hidden="true">↗</span>
          </a>
          <a
            href="mailto:tydobson41@gmail.com"
            class="inline-flex items-center gap-2 rounded-lg border border-border-strong bg-bg-elev px-4 py-2.5 text-sm text-text hover:text-accent hover:border-accent transition-all duration-200 ease-out"
          >
            Email Tyler
          </a>
          <a
            href="https://www.linkedin.com/in/tylerdobson"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 rounded-lg border border-border-strong bg-bg-elev px-4 py-2.5 text-sm text-text hover:text-accent hover:border-accent transition-all duration-200 ease-out"
          >
            LinkedIn <span aria-hidden="true">↗</span>
          </a>
          <a
            href="https://github.com/tylerdobson"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 rounded-lg border border-border-strong bg-bg-elev px-4 py-2.5 text-sm text-text hover:text-accent hover:border-accent transition-all duration-200 ease-out"
          >
            GitHub <span aria-hidden="true">↗</span>
          </a>
        </div>
      </div>

      <div class="lg:justify-self-end w-full max-w-xl lg:max-w-none">
        <ArchitectureDiagram variant="hero" />
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    const section = document.getElementById("hero");
    const glow = document.getElementById("hero-glow");
    if (!section || !glow) return;

    const finePointer = window.matchMedia("(pointer: fine)").matches;
    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (!finePointer || reduced) return;

    let rafId = null;
    let pendingX = 50;
    let pendingY = 50;

    const apply = () => {
      rafId = null;
      glow.style.setProperty("--mx", pendingX + "%");
      glow.style.setProperty("--my", pendingY + "%");
    };

    section.addEventListener("pointerenter", () => glow.classList.add("active"));
    section.addEventListener("pointerleave", () => glow.classList.remove("active"));
    section.addEventListener("pointermove", (e) => {
      const rect = section.getBoundingClientRect();
      pendingX = ((e.clientX - rect.left) / rect.width) * 100;
      pendingY = ((e.clientY - rect.top) / rect.height) * 100;
      if (rafId == null) {
        rafId = window.requestAnimationFrame(apply);
      }
    });
  })();
</script>
