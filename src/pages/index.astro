---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import CurrentlyBuilding from "../components/CurrentlyBuilding.astro";
import About from "../components/About.astro";
import FlagshipCard from "../components/FlagshipCard.astro";
import SectionLabel from "../components/SectionLabel.astro";
import CaseStudySection from "../components/CaseStudySection.astro";
import ProjectCard from "../components/ProjectCard.astro";
import ApproachStep from "../components/ApproachStep.astro";
import SkillTier from "../components/SkillTier.astro";
import Footer from "../components/Footer.astro";

import {
  caseStudies,
  moreProjects,
  approachSteps,
  skillTiers,
} from "../content/projects.ts";

const title = "Tyler Dobson — Data, AI & ML Engineer";
const description =
  "Junior at the University of South Florida building AI-powered systems that turn manual workflows into automated infrastructure. Available Summer 2026 and Fall 2026 for Data, AI, and ML Engineering internships.";
---

<BaseLayout title={title} description={description}>
  <Nav />

  <main>
    <Hero />
    <CurrentlyBuilding />

    <div class="hairline-divider mt-12"></div>

    <About />

    <div class="hairline-divider"></div>

    <section class="px-6 pt-16 sm:px-10">
      <div class="mx-auto max-w-[72rem]">
        <SectionLabel number="01" label="Flagship project" />
      </div>
    </section>
    <FlagshipCard />

    <div class="hairline-divider"></div>

    <section id="case-studies" class="px-6 py-20 sm:px-10 sm:py-24">
      <div class="mx-auto max-w-[72rem]">
        <SectionLabel number="02" label="Case studies" />
        <h2
          class="mt-3 max-w-3xl font-light tracking-tight text-text"
          style="font-size: clamp(1.75rem, 3vw, 2.5rem);"
        >
          Analytics products that ship with findings, not just features.
        </h2>

        <div class="mt-10 grid gap-6 md:grid-cols-2">
          {caseStudies.map((p) => <CaseStudySection project={p} />)}
        </div>
      </div>
    </section>

    <div class="hairline-divider"></div>

    <section class="px-6 py-20 sm:px-10 sm:py-24">
      <div class="mx-auto max-w-[72rem]">
        <SectionLabel number="03" label="More work" />
        <h2
          class="mt-3 max-w-3xl font-light tracking-tight text-text"
          style="font-size: clamp(1.75rem, 3vw, 2.5rem);"
        >
          Additional projects across the data and automation stack.
        </h2>

        <div class="mt-10 grid gap-4 sm:grid-cols-2">
          {moreProjects.map((p) => <ProjectCard project={p} />)}
        </div>
      </div>
    </section>

    <div class="hairline-divider"></div>

    <section id="approach" class="px-6 py-20 sm:px-10 sm:py-24">
      <div class="mx-auto max-w-[72rem]">
        <SectionLabel number="04" label="Approach" />
        <h2
          class="mt-3 max-w-3xl font-light tracking-tight text-text"
          style="font-size: clamp(1.75rem, 3vw, 2.5rem);"
        >
          Systems thinking, packaged for review.
        </h2>
        <p class="mt-5 max-w-3xl text-base leading-relaxed text-text-dim">
          Every project I ship starts with the same question: what's the actual workflow this
          needs to fit into? Then I work backwards — clean data, tested logic, usable interfaces,
          and documentation that explains both decisions and limits.
        </p>

        <div class="mt-10 grid gap-4 sm:grid-cols-2">
          {
            approachSteps.map((step) => (
              <ApproachStep number={step.number} title={step.title} body={step.body} />
            ))
          }
        </div>
      </div>
    </section>

    <div class="hairline-divider"></div>

    <section class="px-6 py-20 sm:px-10 sm:py-24">
      <div class="mx-auto max-w-[72rem]">
        <SectionLabel number="05" label="Skills" />
        <h2
          class="mt-3 max-w-3xl font-light tracking-tight text-text"
          style="font-size: clamp(1.75rem, 3vw, 2.5rem);"
        >
          Tools and capabilities, organized by tier.
        </h2>

        <div class="mt-10 grid gap-4 md:grid-cols-2">
          {
            skillTiers.map((tier) => (
              <SkillTier tier={tier.tier} label={tier.label} items={tier.items} />
            ))
          }
        </div>
      </div>
    </section>

    <div class="hairline-divider"></div>

    <section id="contact" class="px-6 py-20 sm:px-10 sm:py-24">
      <div class="mx-auto max-w-[72rem]">
        <SectionLabel number="06" label="Contact" />
        <h2
          class="mt-3 max-w-3xl font-light tracking-tight text-text"
          style="font-size: clamp(1.75rem, 3vw, 2.5rem);"
        >
          Open to internship conversations.
        </h2>
        <p class="mt-5 max-w-3xl text-base leading-relaxed text-text-dim">
          Looking for Summer 2026 and Fall 2026 internships in Data Engineering, AI Engineering,
          Machine Learning, Data Science, and Analytics where I can ship real systems.
          Comfortable on small teams, comfortable with ambiguity, comfortable in production.
        </p>

        <div class="mt-8 flex flex-wrap items-center gap-3">
          <a
            href="mailto:tydobson41@gmail.com"
            class="inline-flex items-center gap-2 rounded-lg bg-accent px-4 py-2.5 text-sm font-medium text-white hover:bg-accent-hover transition-all duration-200 ease-out"
          >
            tydobson41@gmail.com
          </a>
          <a
            href="https://www.linkedin.com/in/tylerdobson"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 rounded-lg border border-border-strong bg-bg-elev px-4 py-2.5 text-sm text-text hover:text-accent hover:border-accent transition-all duration-200 ease-out"
          >
            LinkedIn <span aria-hidden="true">↗</span>
          </a>
          <a
            href="https://github.com/tylerdobson"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 rounded-lg border border-border-strong bg-bg-elev px-4 py-2.5 text-sm text-text hover:text-accent hover:border-accent transition-all duration-200 ease-out"
          >
            GitHub <span aria-hidden="true">↗</span>
          </a>
          <a
            href="/resume.pdf"
            class="inline-flex items-center gap-2 rounded-lg border border-border-strong bg-bg-elev px-4 py-2.5 text-sm text-text hover:text-accent hover:border-accent transition-all duration-200 ease-out"
          >
            Download résumé
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
