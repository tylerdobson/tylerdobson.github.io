---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import About from "../components/About.astro";
import FlagshipCard from "../components/FlagshipCard.astro";
import ResumeHighlights from "../components/ResumeHighlights.astro";
import WorkflowEcosystem from "../components/WorkflowEcosystem.astro";
import SectionLabel from "../components/SectionLabel.astro";
import CaseStudySection from "../components/CaseStudySection.astro";
import ProjectCard from "../components/ProjectCard.astro";
import ApproachStep from "../components/ApproachStep.astro";
import Footer from "../components/Footer.astro";

import {
  caseStudies,
  moreProjects,
  approachSteps,
} from "../content/projects.ts";

const title = "Tyler Dobson — Data, AI & ML Engineer";
const description =
  "Junior at the University of South Florida building AI-powered systems that turn manual workflows into automated infrastructure. Available Summer and Fall 2026 for Data, AI, and ML Engineering internships.";
---

<BaseLayout title={title} description={description}>
  <Nav />

  <main>
    <Hero />

    <div class="hairline-divider"></div>

    <About />

    <div class="hairline-divider"></div>

    <section class="px-6 pt-16 sm:px-10">
      <div class="mx-auto max-w-[72rem]">
        <SectionLabel number="02" label="Flagship project" />
      </div>
    </section>
    <FlagshipCard />

    <div class="hairline-divider"></div>

    <ResumeHighlights />

    <div class="hairline-divider"></div>

    <WorkflowEcosystem />

    <div class="hairline-divider"></div>

    <section id="case-studies" class="px-6 py-20 sm:px-10 sm:py-24">
      <div class="mx-auto max-w-[72rem]">
        <SectionLabel number="05" label="Case studies" />
        <h2
          class="mt-3 max-w-3xl font-light tracking-tight text-text"
          style="font-size: clamp(1.75rem, 3vw, 2.5rem);"
        >
          Analytics products that ship with findings, not just features.
        </h2>

        <div class="mt-10 grid gap-6 md:grid-cols-2">
          {caseStudies.map((p) => <CaseStudySection project={p} />)}
        </div>
      </div>
    </section>

    <div class="hairline-divider"></div>

    <section class="px-6 py-20 sm:px-10 sm:py-24">
      <div class="mx-auto max-w-[72rem]">
        <SectionLabel number="06" label="More work" />
        <h2
          class="mt-3 max-w-3xl font-light tracking-tight text-text"
          style="font-size: clamp(1.75rem, 3vw, 2.5rem);"
        >
          Additional projects across the data and automation stack.
        </h2>

        <div class="mt-10 grid gap-4 sm:grid-cols-2">
          {moreProjects.map((p) => <ProjectCard project={p} />)}
        </div>
      </div>
    </section>

    <div class="hairline-divider"></div>

    <section id="approach" class="px-6 py-20 sm:px-10 sm:py-24">
      <div class="mx-auto max-w-[72rem]">
        <SectionLabel number="07" label="Approach" />
        <h2
          class="mt-3 max-w-3xl font-light tracking-tight text-text"
          style="font-size: clamp(1.75rem, 3vw, 2.5rem);"
        >
          Systems thinking, packaged for review.
        </h2>
        <p
          class="mt-5 max-w-3xl font-mono text-sm italic leading-relaxed text-text-dim"
          style="font-family: var(--font-mono);"
        >
          “Lead with a business question — not a tool or a dataset. Document assumptions
          explicitly. Sanitize inputs. Write a real README. Practice evidence discipline — no
          claim of ‘completed’ or ‘production-grade’ without an artifact behind it.”
        </p>

        <div class="mt-10 grid gap-4 sm:grid-cols-2">
          {
            approachSteps.map((step) => (
              <ApproachStep number={step.number} title={step.title} body={step.body} />
            ))
          }
        </div>
      </div>
    </section>

    <div class="hairline-divider"></div>

    <section id="contact" class="px-6 py-20 sm:px-10 sm:py-24">
      <div class="mx-auto max-w-[72rem]">
        <SectionLabel number="08" label="Contact" />
        <h2
          class="mt-3 max-w-3xl font-light tracking-tight text-text"
          style="font-size: clamp(1.75rem, 3vw, 2.5rem);"
        >
          Open to internship conversations.
        </h2>
        <p class="mt-5 max-w-3xl text-base leading-relaxed text-text-dim">
          Looking for Summer and Fall 2026 internships in Data Engineering, AI Engineering,
          Machine Learning, Data Analytics, Business Intelligence, Information Systems, and AI
          Automation. Particularly interested in applying analytics to operations, performance
          analysis, and process optimization. Comfortable on small teams, comfortable with
          ambiguity, comfortable shipping real systems.
        </p>

        <div class="mt-8 flex flex-wrap items-center gap-3">
          <a
            href="mailto:tydobson41@gmail.com"
            class="inline-flex items-center gap-2 rounded-lg bg-accent px-4 py-2.5 text-sm font-medium text-bg hover:bg-accent-hover transition-all duration-200 ease-out"
          >
            tydobson41@gmail.com
          </a>
          <a
            href="https://www.linkedin.com/in/tylerdobson"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 rounded-lg border border-border-strong px-4 py-2.5 text-sm text-text hover:text-accent hover:border-accent transition-all duration-200 ease-out"
          >
            LinkedIn <span aria-hidden="true">↗</span>
          </a>
          <a
            href="https://github.com/tylerdobson"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 rounded-lg border border-border-strong px-4 py-2.5 text-sm text-text hover:text-accent hover:border-accent transition-all duration-200 ease-out"
          >
            GitHub <span aria-hidden="true">↗</span>
          </a>
          <a
            href="/resume/"
            class="inline-flex items-center gap-2 rounded-lg border border-border-strong px-4 py-2.5 text-sm text-text hover:text-accent hover:border-accent transition-all duration-200 ease-out"
          >
            View résumé <span aria-hidden="true">↗</span>
          </a>
          <a
            href="/resume.pdf"
            class="inline-flex items-center gap-2 rounded-lg border border-border-strong px-4 py-2.5 text-sm text-text hover:text-accent hover:border-accent transition-all duration-200 ease-out"
          >
            Download PDF <span aria-hidden="true">↓</span>
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
