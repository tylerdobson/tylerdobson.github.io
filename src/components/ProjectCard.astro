---
import type { SmallProjectData } from "../content/projects.ts";

interface Props {
  project: SmallProjectData;
}

const { project } = Astro.props;
---

<article
  class="flex flex-col overflow-hidden rounded-xl border border-border bg-bg-elev transition-colors hover:border-border-strong"
>
  {
    project.image?.src && (
      <figure class="border-b border-border bg-bg">
        <img
          src={project.image.src}
          alt={project.image.alt}
          width={project.image.width}
          height={project.image.height}
          loading="lazy"
          decoding="async"
          class="block aspect-[3/2] w-full object-cover"
        />
      </figure>
    )
  }

  <div class="flex flex-1 flex-col p-6">
    <p
      class="font-mono text-[10px] uppercase tracking-[0.14em] text-text-muted"
      style="font-family: var(--font-mono);"
    >
      {project.tech.join(" · ")}
    </p>

    <h3 class="mt-2 text-lg font-medium text-text">
      {project.title}
    </h3>

    <p class="mt-3 flex-1 text-sm leading-relaxed text-text-dim">
      {project.description}
    </p>

    <a
      href={project.repo}
      target="_blank"
      rel="noopener"
      class="mt-5 inline-flex items-center gap-2 text-sm text-text-dim hover:text-accent transition-colors self-start"
    >
      Repository <span aria-hidden="true">↗</span>
    </a>
  </div>
</article>
