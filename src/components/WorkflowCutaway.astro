---
import SectionLabel from "./SectionLabel.astro";
import { workflowGroups } from "../content/workflow.ts";
---

<section id="workflow" class="px-6 py-20 sm:px-10 sm:py-24">
  <div class="mx-auto max-w-[72rem]">
    <SectionLabel number="04" label="Workflow systems" />
    <h2
      class="mt-3 max-w-3xl font-light tracking-tight text-text"
      style="font-size: clamp(1.75rem, 3vw, 2.5rem);"
    >
      The applications behind the systems I actually run.
    </h2>
    <p class="mt-5 max-w-3xl text-base leading-relaxed text-text-dim">
      I connect AI tools, automation platforms, analytics surfaces, and documentation habits into
      repeatable workflows. Each tool below is part of a public-facing project, resume proof point,
      or recruiter-safe operating system.
    </p>

    <div class="mt-10 overflow-hidden rounded-xl border border-border bg-bg-elev">
      {
        workflowGroups.map((group) => (
          <div class="grid gap-6 border-b border-border p-6 last:border-b-0 lg:grid-cols-[14rem_1fr] lg:p-7">
            <div>
              <p
                class="font-mono text-xs uppercase tracking-[0.14em] text-accent"
                style="font-family: var(--font-mono);"
              >
                {group.label}
              </p>
              <h3 class="mt-2 text-lg font-medium leading-snug text-text">{group.heading}</h3>
            </div>

            <div class="grid gap-x-6 gap-y-4 sm:grid-cols-2 xl:grid-cols-3">
              {group.tools.map((tool) => (
                <div class="border-l border-border-strong pl-4">
                  <div class="text-sm font-medium text-text">{tool.name}</div>
                  <div class="mt-1 text-sm leading-relaxed text-text-dim">{tool.role}</div>
                </div>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
